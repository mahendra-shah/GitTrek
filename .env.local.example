GITHUB_CLIENT_ID=       # GitHub → Settings → Developer Settings → OAuth Apps → your app → Client ID
GITHUB_CLIENT_SECRET=   # Same OAuth App → generate a new client secret — shown once, copy immediately
GITHUB_REDIRECT_URI=    # http://localhost:5173/api/auth/callback for local dev (adjust port if different)
COOKIE_SECRET=          # Random 32-char hex string — generate with: openssl rand -hex 32
GITHUB_BOT_TOKEN=       # Optional: comma-separated GitHub PATs — increases guest search capacity
